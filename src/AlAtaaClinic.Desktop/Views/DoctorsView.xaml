<UserControl x:Class="AlAtaaClinic.Desktop.Views.DoctorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AlAtaaClinic.Desktop.Controls"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer Background="{DynamicResource Brush.BackgroundAlt}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="{l:Loc PageTitle.Doctors}"
                       Style="{StaticResource Text.PageTitle}" />
            <Border Grid.Row="2"
                    Style="{StaticResource Card}" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <controls:SearchBar Text="{Binding SearchText}"
                                        SearchCommand="{Binding SearchCommand}" />
                    <Button Grid.Column="2"
                            Content="{l:Loc Common.New}"
                            Style="{StaticResource Button.Primary}"
                            Command="{Binding AddCommand}" />
                    <Button Grid.Column="4"
                            Content="{l:Loc Common.Edit}"
                            Style="{StaticResource Button.Secondary}"
                            Command="{Binding EditCommand}" />
                    <Button Grid.Column="6"
                            Content="{l:Loc Common.Deactivate}"
                            Style="{StaticResource Button.Danger}"
                            Command="{Binding DeleteCommand}" />
                    <Button Grid.Column="8"
                            Content="{l:Loc Common.Print}"
                            Style="{StaticResource Button.Secondary}"
                            Command="{Binding PrintCommand}" />
                </Grid>
            </Border>
            <Border Grid.Row="4"
                    Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Doctors}"
                          SelectedItem="{Binding SelectedDoctor}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{l:Loc Common.Name}"
                                            Binding="{Binding StaffMemberName}"
                                            Width="*" />
                        <DataGridTextColumn Header="{l:Loc Common.StaffCode}"
                                            Binding="{Binding StaffCode}"
                                            Width="120" />
                        <DataGridTextColumn Header="{l:Loc Common.Specialty}"
                                            Binding="{Binding Specialty}"
                                            Width="*" />
                        <DataGridTextColumn Header="{l:Loc Common.License}"
                                            Binding="{Binding LicenseNumber}"
                                            Width="140" />
                        <DataGridCheckBoxColumn Header="{l:Loc Common.Active}"
                                                Binding="{Binding IsActive}"
                                                Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
