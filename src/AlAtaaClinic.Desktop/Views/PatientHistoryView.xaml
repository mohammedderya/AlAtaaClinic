<UserControl x:Class="AlAtaaClinic.Desktop.Views.PatientHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer Background="{DynamicResource Brush.BackgroundAlt}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{l:Loc Common.PatientSearch}"
                               Style="{StaticResource Text.SectionTitle}"
                               Margin="0,0,0,14" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Content="{l:Loc Common.Search}"
                                Command="{Binding SearchPatientCommand}"
                                Style="{StaticResource Button.Primary}" />
                    </Grid>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource Brush.Danger}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding ValidationMessages.Count, StringFormat='Patients: {0}'}"
                               Style="{StaticResource Text.Muted}"
                               Margin="0,10,0,6" />
                    <ListBox ItemsSource="{Binding Patients}"
                             SelectedItem="{Binding SelectedPatient}"
                             MinHeight="120"
                             MaxHeight="300"
                             DisplayMemberPath="FullNameArabic" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{l:Loc Common.VisitHistory}"
                                   Style="{StaticResource Text.PageTitle}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Content="{l:Loc Common.NewVisit}"
                                Command="{Binding AddVisitCommand}"
                                Style="{StaticResource Button.Primary}" />
                        <Button Grid.Column="4"
                                Content="{l:Loc Common.Edit}"
                                Command="{Binding EditVisitCommand}"
                                Style="{StaticResource Button.Secondary}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{l:Loc Common.Visits}"
                                       Style="{StaticResource Text.SectionTitle}"
                                       Margin="0,0,0,10" />
                            <ListBox ItemsSource="{Binding Visits}"
                                     SelectedItem="{Binding SelectedVisit}"
                                     MinHeight="200"
                                     DisplayMemberPath="ChiefComplaint" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="2"
                                  VerticalScrollBarVisibility="Auto"
                                  DataContext="{Binding VisitDetail}">
                        <Border Style="{StaticResource Card}" Padding="24,20">
                            <StackPanel>
                                <TextBlock Text="{l:Loc Common.VisitDetails}"
                                           Style="{StaticResource Text.SectionTitle}"
                                           Margin="0,0,0,16" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{l:Loc Common.Date}"
                                                   Style="{StaticResource Text.Muted}" />
                                        <TextBlock Text="{Binding VisitDate}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{l:Loc Common.Status}"
                                                   Style="{StaticResource Text.Muted}" />
                                        <TextBlock Text="{Binding Status}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{l:Loc Common.ChiefComplaint}"
                                           Style="{StaticResource Text.Muted}"
                                           Margin="0,14,0,0" />
                                <TextBlock Text="{Binding ChiefComplaint}"
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Margin="0,4,0,0" />

                                <TextBlock Text="{l:Loc Common.ClinicalNotes}"
                                           Style="{StaticResource Text.Muted}"
                                           Margin="0,14,0,0" />
                                <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                        CornerRadius="8"
                                        Padding="14,10"
                                        Margin="0,6,0,0">
                                    <TextBlock Text="{Binding ClinicalNotes}"
                                               TextWrapping="Wrap"
                                               FontSize="13" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
