<UserControl x:Class="AlAtaaClinic.Desktop.Views.PatientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AlAtaaClinic.Desktop.Controls"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer Background="{DynamicResource Brush.BackgroundAlt}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="{l:Loc PageTitle.Patients}"
                       Style="{StaticResource Text.PageTitle}" />
            <Border Grid.Row="2"
                    Style="{StaticResource Card}" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <controls:SearchBar Text="{Binding SearchText}"
                                        SearchCommand="{Binding SearchCommand}" />
                    <Button Grid.Column="2"
                            Content="{l:Loc Common.New}"
                            Style="{StaticResource Button.Primary}"
                            Command="{Binding AddCommand}" />
                    <Button Grid.Column="4"
                            Content="{l:Loc Common.Edit}"
                            Style="{StaticResource Button.Secondary}"
                            Command="{Binding EditCommand}" />
                    <Button Grid.Column="6"
                            Content="{l:Loc Common.Deactivate}"
                            Style="{StaticResource Button.Danger}"
                            Command="{Binding DeleteCommand}" />
                    <Button Grid.Column="8"
                            Content="{l:Loc Common.Print}"
                            Style="{StaticResource Button.Secondary}"
                            Command="{Binding PrintCommand}" />
                </Grid>
            </Border>
            <Border Grid.Row="4"
                    Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Patients}"
                          SelectedItem="{Binding SelectedPatient}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{l:Loc Common.File}"
                                            Binding="{Binding FileNumber}"
                                            Width="120" />
                        <DataGridTextColumn Header="{l:Loc Common.ArabicName}"
                                            Binding="{Binding FullNameArabic}"
                                            Width="*" />
                        <DataGridTextColumn Header="{l:Loc Common.Phone}"
                                            Binding="{Binding PhoneNumber}"
                                            Width="160" />
                        <DataGridTextColumn Header="{l:Loc Common.Gender}"
                                            Binding="{Binding Gender}"
                                            Width="100" />
                        <DataGridCheckBoxColumn Header="{l:Loc Common.Active}"
                                                Binding="{Binding IsActive}"
                                                Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
