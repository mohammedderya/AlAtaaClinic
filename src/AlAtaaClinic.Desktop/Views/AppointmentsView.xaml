<UserControl x:Class="AlAtaaClinic.Desktop.Views.AppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer Background="{StaticResource Brush.BackgroundAlt}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="{l:Loc PageTitle.Appointments}" Style="{StaticResource Text.PageTitle}" Margin="0,0,0,20" />
            <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DatePicker SelectedDate="{Binding From}" />
                    <DatePicker Grid.Column="2" SelectedDate="{Binding To}" />
                    <TextBox Grid.Column="4" Text="{Binding DoctorId, UpdateSourceTrigger=PropertyChanged}" ToolTip="Doctor ID" />
                    <Button Grid.Column="6" Content="{l:Loc Common.Search}" Style="{StaticResource Button.Primary}" Command="{Binding SearchCommand}" />
                    <Button Grid.Column="8" Content="{l:Loc Common.New}" Style="{StaticResource Button.Secondary}" Command="{Binding AddCommand}" />
                    <Button Grid.Column="10" Content="{l:Loc Common.Edit}" Style="{StaticResource Button.Secondary}" Command="{Binding EditCommand}" />
                    <Button Grid.Column="12" Content="{l:Loc Common.Print}" Style="{StaticResource Button.Secondary}" Command="{Binding PrintCommand}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}" RowHeight="44" AlternatingRowBackground="#F3F4F6" GridLinesVisibility="None" HeadersVisibility="Column" BorderThickness="0" Background="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{l:Loc Common.Start}" Binding="{Binding AppointmentStart, StringFormat={}{0:g}}" Width="170" />
                        <DataGridTextColumn Header="{l:Loc Common.End}" Binding="{Binding AppointmentEnd, StringFormat={}{0:g}}" Width="170" />
                        <DataGridTextColumn Header="{l:Loc Common.PatientId}" Binding="{Binding PatientId}" Width="110" />
                        <DataGridTextColumn Header="{l:Loc Common.DoctorId}" Binding="{Binding DoctorId}" Width="110" />
                        <DataGridTextColumn Header="{l:Loc Common.Status}" Binding="{Binding Status}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
