<UserControl x:Class="AlAtaaClinic.Desktop.Views.VisitsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer Background="{StaticResource Brush.BackgroundAlt}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="{l:Loc PageTitle.Visits}" Style="{StaticResource Text.PageTitle}" Margin="0,0,0,20" />
            <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding PatientId, UpdateSourceTrigger=PropertyChanged}" ToolTip="Patient ID" />
                    <TextBox Grid.Column="2" Text="{Binding DoctorId, UpdateSourceTrigger=PropertyChanged}" ToolTip="Doctor ID" />
                    <DatePicker Grid.Column="4" SelectedDate="{Binding From}" />
                    <DatePicker Grid.Column="6" SelectedDate="{Binding To}" />
                    <Button Grid.Column="8" Content="{l:Loc Common.Search}" Style="{StaticResource Button.Primary}" Command="{Binding SearchCommand}" />
                    <Button Grid.Column="10" Content="{l:Loc Common.New}" Style="{StaticResource Button.Secondary}" Command="{Binding AddCommand}" />
                    <Button Grid.Column="12" Content="{l:Loc Common.Edit}" Style="{StaticResource Button.Secondary}" Command="{Binding EditCommand}" />
                    <Button Grid.Column="14" Content="{l:Loc Common.Cancel}" Style="{StaticResource Button.Danger}" Command="{Binding CancelCommand}" />
                    <Button Grid.Column="16" Content="{l:Loc Common.Print}" Style="{StaticResource Button.Secondary}" Command="{Binding PrintCommand}" />
                </Grid>
            </Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding Visits}" SelectedItem="{Binding SelectedVisit}" RowHeight="44" AlternatingRowBackground="#F3F4F6" GridLinesVisibility="None" HeadersVisibility="Column" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{l:Loc Common.Date}" Binding="{Binding VisitDate, StringFormat={}{0:g}}" Width="150" />
                            <DataGridTextColumn Header="{l:Loc Common.Patient}" Binding="{Binding PatientId}" Width="90" />
                            <DataGridTextColumn Header="{l:Loc Common.Doctor}" Binding="{Binding DoctorId}" Width="90" />
                            <DataGridTextColumn Header="{l:Loc Common.Status}" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="{l:Loc Common.Complaint}" Binding="{Binding ChiefComplaint}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{l:Loc Common.VisitDetail}" Style="{StaticResource Text.SectionTitle}" />
                            <TextBlock Text="{Binding VisitDetail.ChiefComplaint}" FontSize="18" FontWeight="SemiBold" Margin="0,14,0,4" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding VisitDetail.ClinicalNotes}" Style="{StaticResource Text.Muted}" TextWrapping="Wrap" />
                            <TextBlock Text="{l:Loc Common.Diagnoses}" Style="{StaticResource Text.SectionTitle}" Margin="0,18,0,6" />
                            <ItemsControl ItemsSource="{Binding VisitDetail.Diagnoses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" Margin="0,3" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
