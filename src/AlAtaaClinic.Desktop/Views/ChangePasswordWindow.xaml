<Window x:Class="AlAtaaClinic.Desktop.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password Required"
        Width="460"
        Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Border Style="{StaticResource Card}"
            Margin="24"
            Padding="28">
        <StackPanel>
            <TextBlock Text="Change Password"
                       FontFamily="{StaticResource Font.App}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text}" />
            <TextBlock Text="You must set a new password before continuing."
                       Style="{StaticResource Text.Muted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,24" />

            <TextBlock Text="New Password"
                       FontSize="13"
                       FontWeight="Medium"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       Margin="0,0,0,6" />
            <PasswordBox x:Name="NewPasswordInput"
                         Margin="0,0,0,16"
                         FontSize="14" />

            <TextBlock Text="Confirm Password"
                       FontSize="13"
                       FontWeight="Medium"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       Margin="0,0,0,6" />
            <PasswordBox x:Name="ConfirmPasswordInput"
                         Margin="0,0,0,16"
                         FontSize="14" />

            <TextBlock x:Name="ErrorText"
                       Foreground="{DynamicResource Brush.Danger}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14" />

            <Button Content="Update Password"
                    Command="{Binding ChangePasswordCommand}"
                    Style="{StaticResource Button.Primary}"
                    HorizontalAlignment="Stretch"
                    MinHeight="44" />
        </StackPanel>
    </Border>
</Window>
