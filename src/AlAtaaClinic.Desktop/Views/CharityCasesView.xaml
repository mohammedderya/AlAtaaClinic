<UserControl x:Class="AlAtaaClinic.Desktop.Views.CharityCasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer Background="{DynamicResource Brush.BackgroundAlt}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="{l:Loc PageTitle.Charity}" Style="{StaticResource Text.PageTitle}" />
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding PatientId, UpdateSourceTrigger=PropertyChanged}" ToolTip="Patient ID" />
                    <TextBox Grid.Column="2" Text="{Binding CaseNumber, UpdateSourceTrigger=PropertyChanged}" ToolTip="Case number" />
                    <Button Grid.Column="4" Content="{l:Loc Common.Search}" Style="{StaticResource Button.Primary}" Command="{Binding SearchCommand}" />
                    <Button Grid.Column="6" Content="{l:Loc Common.New}" Style="{StaticResource Button.Secondary}" Command="{Binding AddCommand}" />
                    <Button Grid.Column="8" Content="{l:Loc Common.Edit}" Style="{StaticResource Button.Secondary}" Command="{Binding EditCommand}" />
                    <Button Grid.Column="10" Content="{l:Loc Common.Suspend}" Style="{StaticResource Button.Danger}" Command="{Binding DeleteCommand}" />
                    <Button Grid.Column="12" Content="{l:Loc Common.Print}" Style="{StaticResource Button.Secondary}" Command="{Binding PrintCommand}" />
                </Grid>
            </Border>
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0">
                <DataGrid ItemsSource="{Binding CharityCases}" SelectedItem="{Binding SelectedCharityCase}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{l:Loc Common.Case}" Binding="{Binding CaseNumber}" Width="150" />
                        <DataGridTextColumn Header="{l:Loc Common.Patient}" Binding="{Binding PatientId}" Width="100" />
                        <DataGridTextColumn Header="{l:Loc Common.Status}" Binding="{Binding EligibilityStatus}" Width="150" />
                        <DataGridTextColumn Header="{l:Loc Common.CoveragePercentage}" Binding="{Binding CoveragePercentage, StringFormat={}{0:N2}}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
