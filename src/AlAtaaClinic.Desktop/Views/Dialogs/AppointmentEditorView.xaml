<UserControl x:Class="AlAtaaClinic.Desktop.Views.Dialogs.AppointmentEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AlAtaaClinic.Desktop.Controls">
    <StackPanel>
        <controls:ValidationSummary Messages="{Binding ValidationMessages}" Margin="0,0,0,16" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="Branch ID" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding BranchId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Patient ID" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding PatientId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <TextBlock Text="Doctor ID" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding DoctorId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                <TextBlock Text="Status" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                <TextBlock Text="Start" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding AppointmentStart, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:g}}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,12,0,0">
                <TextBlock Text="End" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding AppointmentEnd, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:g}}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Margin="0,12,0,0">
                <TextBlock Text="Notes" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True" />
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
