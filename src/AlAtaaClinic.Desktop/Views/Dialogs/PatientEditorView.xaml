<UserControl x:Class="AlAtaaClinic.Desktop.Views.Dialogs.PatientEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AlAtaaClinic.Desktop.Controls">
    <StackPanel>
        <controls:ValidationSummary Messages="{Binding ValidationMessages}" Margin="0,0,0,16" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="File Number" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding FileNumber, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="National ID" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <TextBlock Text="Arabic Name" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding FullNameArabic, UpdateSourceTrigger=PropertyChanged}"
                         FlowDirection="RightToLeft" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                <TextBlock Text="English Name" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding FullNameEnglish, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                <TextBlock Text="Gender" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding Genders}" SelectedItem="{Binding Gender}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,12,0,0">
                <TextBlock Text="Date of Birth" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <DatePicker SelectedDate="{Binding DateOfBirth}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock Text="Phone" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,12,0,0">
                <TextBlock Text="Alternative Phone" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding AlternativePhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="4" Margin="0,12,0,0">
                <TextBlock Text="Blood Type" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding BloodType, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,12,0,0">
                <TextBlock Text="Address" Style="{StaticResource Text.Muted}" Margin="0,0,0,6" />
                <TextBox Text="{Binding AddressLine, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
