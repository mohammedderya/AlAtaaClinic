<UserControl x:Class="AlAtaaClinic.Desktop.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer Background="{StaticResource Brush.BackgroundAlt}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="{l:Loc PageTitle.Billing}" Style="{StaticResource Text.PageTitle}" Margin="0,0,0,20" />
            <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding PatientId, UpdateSourceTrigger=PropertyChanged}" ToolTip="Patient ID" />
                    <TextBox Grid.Column="2" Text="{Binding Status, UpdateSourceTrigger=PropertyChanged}" ToolTip="Status" />
                    <Button Grid.Column="4" Content="{l:Loc Common.Search}" Style="{StaticResource Button.Primary}" Command="{Binding SearchCommand}" />
                    <Button Grid.Column="6" Content="{l:Loc Common.New}" Style="{StaticResource Button.Secondary}" Command="{Binding AddCommand}" />
                    <Button Grid.Column="8" Content="{l:Loc Common.Edit}" Style="{StaticResource Button.Secondary}" Command="{Binding EditCommand}" />
                    <Button Grid.Column="10" Content="{l:Loc Common.Payment}" Style="{StaticResource Button.Secondary}" Command="{Binding AddPaymentCommand}" />
                    <Button Grid.Column="12" Content="{l:Loc Common.Void}" Style="{StaticResource Button.Danger}" Command="{Binding VoidCommand}" />
                    <Button Grid.Column="14" Content="{l:Loc Common.Print}" Style="{StaticResource Button.Secondary}" Command="{Binding PrintCommand}" />
                </Grid>
            </Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding Invoices}" SelectedItem="{Binding SelectedInvoice}" RowHeight="44" AlternatingRowBackground="#F3F4F6" GridLinesVisibility="None" HeadersVisibility="Column" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{l:Loc Common.Number}" Binding="{Binding InvoiceNumber}" Width="150" />
                            <DataGridTextColumn Header="{l:Loc Common.Patient}" Binding="{Binding PatientId}" Width="90" />
                            <DataGridTextColumn Header="{l:Loc Common.Status}" Binding="{Binding Status}" Width="130" />
                            <DataGridTextColumn Header="{l:Loc Common.Net}" Binding="{Binding NetAmount, StringFormat={}{0:N2}}" Width="110" />
                            <DataGridTextColumn Header="{l:Loc Common.CreatedAt}" Binding="{Binding CreatedAt, StringFormat={}{0:g}}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{l:Loc Common.InvoiceDetail}" Style="{StaticResource Text.SectionTitle}" />
                        <TextBlock Text="{Binding InvoiceDetail.InvoiceNumber}" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,8" />
                        <TextBlock Text="{Binding InvoiceDetail.NetAmount, StringFormat={}Net amount: {0:N2}}" />
                        <TextBlock Text="{l:Loc Common.Lines}" Style="{StaticResource Text.SectionTitle}" Margin="0,18,0,6" />
                        <ItemsControl ItemsSource="{Binding InvoiceDetail.Lines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Description}" />
                                        <TextBlock Grid.Column="1" Text="{Binding LineTotal, StringFormat={}{0:N2}}" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
