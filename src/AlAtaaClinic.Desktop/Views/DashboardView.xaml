<UserControl x:Class="AlAtaaClinic.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AlAtaaClinic.Desktop.Controls"
             xmlns:l="clr-namespace:AlAtaaClinic.Desktop.Common">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource Brush.BackgroundAlt}">
        <StackPanel Margin="28,24,28,28">

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{l:Loc PageTitle.Dashboard}"
                               Style="{StaticResource Text.PageTitle}" />
                    <TextBlock Text="{l:Loc Common.DashboardSubtitle}"
                               Style="{StaticResource Text.Muted}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{l:Loc Common.Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource Button.Secondary}" />
            </Grid>

            <Border Style="{StaticResource Card}"
                    Padding="0"
                    Margin="0,0,0,20"
                    Background="{DynamicResource Brush.PrimaryGradient}">
                <Grid Margin="28,22,28,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="44"
                            Height="44"
                            CornerRadius="11"
                            Background="White"
                            Opacity="0.18"
                            VerticalAlignment="Center"
                            Margin="0,0,18,0">
                        <TextBlock Text="+"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Good to see you!"
                                   FontFamily="{StaticResource Font.App}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Text="Here's what's happening at your clinic today."
                                   FontFamily="{StaticResource Font.Body}"
                                   FontSize="13"
                                   Foreground="White"
                                   Opacity="0.8"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,16"
                                CornerRadius="12"
                                Padding="22,20"
                                Background="{DynamicResource Brush.Surface}"
                                Effect="{DynamicResource Shadow.Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource Text.Muted}"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding Value}"
                                               FontFamily="{StaticResource Font.App}"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text}" />
                                    <TextBlock Text="{Binding Detail}"
                                               Style="{StaticResource Text.Muted}"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{Binding AccentBrushKey, Converter={StaticResource ResourceBrushConverter}}"
                                        CornerRadius="2" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}"
                        CornerRadius="14"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="{l:Loc Common.Activity}"
                                   Style="{StaticResource Text.SectionTitle}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Weekly patient visit trends"
                                   Style="{StaticResource Text.Muted}"
                                   Margin="0,0,0,14" />
                        <controls:BarChart ItemsSource="{Binding ActivityChart}"
                                           Margin="0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource Card}"
                        CornerRadius="14"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="{l:Loc Common.ClinicFocus}"
                                   Style="{StaticResource Text.SectionTitle}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{l:Loc Common.ClinicFocusDescription}"
                                   Style="{StaticResource Text.Muted}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />
                        <Border Background="{DynamicResource Brush.PrimaryLight}"
                                CornerRadius="10"
                                Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Need help?"
                                           FontFamily="{StaticResource Font.App}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.PrimaryDark}" />
                                <TextBlock Text="Contact the admin panel for dashboard configuration."
                                           FontFamily="{StaticResource Font.Body}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.PrimaryDark}"
                                           TextWrapping="Wrap"
                                           Opacity="0.8"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
