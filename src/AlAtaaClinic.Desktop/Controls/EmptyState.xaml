<UserControl x:Class="AlAtaaClinic.Desktop.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Padding="28">
        <StackPanel HorizontalAlignment="Center" MaxWidth="460">
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource Text.SectionTitle}"
                       TextAlignment="Center" />
            <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource Text.Muted}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</UserControl>
