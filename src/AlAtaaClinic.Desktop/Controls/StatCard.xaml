<UserControl x:Class="AlAtaaClinic.Desktop.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource Text.Muted}" />
                <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,6,0,0" />
                <TextBlock Text="{Binding Detail, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource Text.Muted}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Border Grid.Column="1"
                    Background="{Binding AccentBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CornerRadius="4" />
        </Grid>
    </Border>
</UserControl>
