<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Luxury Medical Color Palette -->
    <Color x:Key="Color.Background">#FFFFFF</Color>
    <Color x:Key="Color.BackgroundAlt">#F3F4F6</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceAlt">#F9FAFB</Color>
    <Color x:Key="Color.Border">#E5E7EB</Color>
    <Color x:Key="Color.Text">#1F2937</Color>
    <Color x:Key="Color.TextMuted">#6B7280</Color>
    <Color x:Key="Color.TextLight">#9CA3AF</Color>

    <!-- Primary: Deep Teal/Cyan -->
    <Color x:Key="Color.Primary">#0891B2</Color>
    <Color x:Key="Color.PrimaryLight">#E0F7FA</Color>
    <Color x:Key="Color.PrimaryDark">#0E7490</Color>
    <Color x:Key="Color.PrimaryGradientStart">#0891B2</Color>
    <Color x:Key="Color.PrimaryGradientEnd">#06B6D4</Color>

    <!-- Secondary: Pale Gold Accent -->
    <Color x:Key="Color.Accent">#FCD34D</Color>
    <Color x:Key="Color.AccentDark">#F59E0B</Color>

    <!-- Status Colors -->
    <Color x:Key="Color.Success">#10B981</Color>
    <Color x:Key="Color.SuccessLight">#D1FAE5</Color>
    <Color x:Key="Color.Warning">#F59E0B</Color>
    <Color x:Key="Color.WarningLight">#FEF3C7</Color>
    <Color x:Key="Color.Danger">#EF4444</Color>
    <Color x:Key="Color.DangerLight">#FEE2E2</Color>
    <Color x:Key="Color.Info">#3B82F6</Color>
    <Color x:Key="Color.InfoLight">#DBEAFE</Color>

    <!-- Navigation -->
    <Color x:Key="Color.Navigation">#0F172A</Color>
    <Color x:Key="Color.NavigationHover">#1E293B</Color>
    <Color x:Key="Color.NavigationActive">#0891B2</Color>
    <Color x:Key="Color.NavigationText">#CBD5E1</Color>
    <Color x:Key="Color.NavigationTextActive">#FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.BackgroundAlt" Color="{StaticResource Color.BackgroundAlt}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Color.Text}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.TextLight" Color="{StaticResource Color.TextLight}" />

    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.PrimaryLight" Color="{StaticResource Color.PrimaryLight}" />
    <SolidColorBrush x:Key="Brush.PrimaryDark" Color="{StaticResource Color.PrimaryDark}" />
    <LinearGradientBrush x:Key="Brush.PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Color.PrimaryGradientStart}" Offset="0" />
        <GradientStop Color="{StaticResource Color.PrimaryGradientEnd}" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentDark" Color="{StaticResource Color.AccentDark}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.SuccessLight" Color="{StaticResource Color.SuccessLight}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.WarningLight" Color="{StaticResource Color.WarningLight}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />
    <SolidColorBrush x:Key="Brush.DangerLight" Color="{StaticResource Color.DangerLight}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}" />
    <SolidColorBrush x:Key="Brush.InfoLight" Color="{StaticResource Color.InfoLight}" />

    <SolidColorBrush x:Key="Brush.Navigation" Color="{StaticResource Color.Navigation}" />
    <SolidColorBrush x:Key="Brush.NavigationHover" Color="{StaticResource Color.NavigationHover}" />
    <SolidColorBrush x:Key="Brush.NavigationActive" Color="{StaticResource Color.NavigationActive}" />
    <SolidColorBrush x:Key="Brush.NavigationText" Color="{StaticResource Color.NavigationText}" />
    <SolidColorBrush x:Key="Brush.NavigationTextActive" Color="{StaticResource Color.NavigationTextActive}" />

    <!-- Shadows -->
    <DropShadowEffect x:Key="Shadow.Card" BlurRadius="16" ShadowDepth="2" Direction="270" Opacity="0.06" Color="#000000" />
    <DropShadowEffect x:Key="Shadow.CardHover" BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.10" Color="#000000" />
    <DropShadowEffect x:Key="Shadow.Header" BlurRadius="8" ShadowDepth="1" Direction="270" Opacity="0.05" Color="#000000" />
    <DropShadowEffect x:Key="Shadow.Button" BlurRadius="8" ShadowDepth="2" Direction="270" Opacity="0.12" Color="#0891B2" />

</ResourceDictionary>
